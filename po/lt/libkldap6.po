#: core/ldapconnection.cpp:126
#, kde-format
msgid "No LDAP Support..."
msgstr "Nėra LDAP palaikymo..."

#: core/ldapconnection.cpp:243
#, kde-format
msgid "An error occurred during the connection initialization phase."
msgstr "Ryšio inicijavimo fazės metu įvyko klaida."

#: core/ldapconnection.cpp:250
#, kde-format
msgid "Cannot set protocol version to %1."
msgstr "Nepavyksta nustatyti protokolo versiją į %1."

#: core/ldapconnection.cpp:261
#, kde-format
msgid "Cannot set timeout to %1 second."
msgid_plural "Cannot set timeout to %1 seconds."
msgstr[0] "Nepavyksta nustatyti skirtąjį laiką į %1 sekundę."
msgstr[1] "Nepavyksta nustatyti skirtąjį laiką į %1 sekundes."
msgstr[2] "Nepavyksta nustatyti skirtąjį laiką į %1 sekundžių."
msgstr[3] "Nepavyksta nustatyti skirtąjį laiką į %1 sekundę."

#: core/ldapconnection.cpp:273
#, kde-format
msgid "Could not set CA certificate file."
msgstr "Nepavyko nustatyti LĮ liudijimo failo."

#: core/ldapconnection.cpp:298
#, kde-format
msgid "Invalid TLS require certificate mode."
msgstr "Neteisinga TLS liudijimo reikalavimo veiksena."

#: core/ldapconnection.cpp:303
#, kde-format
msgid "Could not set TLS require certificate mode."
msgstr "Nepavyko nustatyti TLS liudijimo reikalavimo veiksenos."

#: core/ldapconnection.cpp:312
#, kde-format
msgid "Could not initialize new TLS context."
msgstr "Nepavyko inicijuoti naujo TLS konteksto."

#: core/ldapconnection.cpp:329
#, kde-format
msgid "TLS support not available in the LDAP client libraries."
msgstr "TLS nepalaikomas LDAP kliento programos bibliotekose."

#: core/ldapconnection.cpp:339
#, kde-format
msgid "Cannot set size limit."
msgstr "Nepavyksta nustatyti dydžio limito."

#: core/ldapconnection.cpp:349
#, kde-format
msgid "Cannot set time limit."
msgstr "Nepavyksta nustatyti laiko limito."

#: core/ldapconnection.cpp:357
#, kde-format
msgid "Cannot initialize the SASL client."
msgstr "Nepavyksta inicijuoti SASL kliento programos."

#: core/ldapconnection.cpp:434
#, kde-format
msgid ""
"LDAP support not compiled in. Please recompile libkldap with the OpenLDAP "
"(or compatible) client libraries, or complain to your distribution packagers."
msgstr ""
"LDAP palaikymas nėra įkompiliuotas. Sukompiliuokite libkldap iš naujo "
"naudodami OpenLDAP (ar suderinamos) kliento programos bibliotekas arba "
"pasiskųskite savo platinamojo paketo pakuotojams."

#: core/ldapsearch.cpp:222
#, kde-format
msgid "Cannot access to server. Please reconfigure it."
msgstr "Nepavyksta pasiekti serverio. Sukonfigūruokite jį iš naujo."

